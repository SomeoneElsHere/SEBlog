@{
    ViewData["Title"] = "Alarm";
}
<h1>@ViewData["Title"]</h1>
<div style="float:right; display:block">
    <img style="height:200px; width:200px; top:-200px; background-color:none; display:block;" src="/lib/chaosmod_icon.png" asp-append-version="true" alt="oops" />
    <but style="display:inline-block; float:left; margin-top:50px; margin-left:130px; padding-left:20px; padding-right:20px">
        <a style="color:black; text-decoration:none; font-size:18px" asp-area="" asp-controller="Home" asp-action="Download" asp-route-file="Alarm.flo">DOWNLOAD</a>
    </but>
</div>
<p style="padding-top:50px; background-color:none">This is an alarm I made for the app Automate!</p>
<p style="background-color:none">Unlike other alarms, it will keep going off untill you stop it!</p>
<p style="background-color:none">You will have to change the directory of the song you want to play when it goes off.</p>
<p style="background-color:none">Also needs permissions to play music if your phone is in do not disturb, plus other things.</p>

