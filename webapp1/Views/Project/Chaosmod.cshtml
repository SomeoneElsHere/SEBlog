@{
    ViewData["Title"] = "Chaosmod";
}
<h1>@ViewData["Title"]</h1>
<div style="float:right; display:block">
    <img style="height:200px; width:200px; top:-200px; background-color:none; display:block;" src="/lib/chaosmod_icon.png" asp-append-version="true" alt="oops" />
    <but style="display:inline-block; float:left; margin-top:100px">
        <a style="color:black; text-decoration:none;" href="https://www.nexusmods.com/stardewvalley/mods/43705">NON PG-13 RELEASE</a>
</but>
    <but style="display:inline-block; margin-top:100px; margin-left:100px">
        <a style="text-decoration:none; color:black; display:inline" href="https://forums.stardewvalley.net/resources/chaosmod-not-being-updated-wip.153/">PG-13 RELEASE</a>
</but>
</div>
<p style="padding-top:50px; background-color:none">The Chaosmod is a Stardew Valley mod that I am very proud of!</p>
<p style="background-color:none">I've been working on it since HS and it has 5,000 downloads as of 2026!</p>
<p style="background-color:none">Though I have some of my original ideas in there, it wouldnt be what it is now without the community! Thank you all!</p>
