@{
    ViewData["Title"] = "MipsMap";
}
<h1>@ViewData["Title"]</h1>
<div style="float:right; display:block">
    <img style="height:200px; width:200px; top:-200px; background-color:none; display:block;" src="/lib/pics/mipsmap.png" asp-append-version="true" alt="oops" />
    <but style="display:inline-block; float:left; margin-top:50px; margin-left:130px; padding-left:20px; padding-right:20px">
        <a style="color:black; text-decoration:none; font-size:18px" asp-area="" asp-controller="Home" asp-action="Download" asp-route-file="MipsMap.zip">DOWNLOAD</a>
    </but>
</div>
<p style="padding-top:50px; background-color:none">This is a graphical module I made for mips!</p>
<p style="background-color:none">It is bare bones but if you want to use it you can :3</p>
<p style="background-color:none">Supports basic punctuation, only capital letters, and numbers, plus straight and vertical lines.</p>