@{
    ViewData["Title"] = "Misc";
    
}
<div class="text-light text-start" style=" justify-content:start; border-top:solid; border-bottom:solid; border-color:ghostwhite;">
    <h1 style="padding-left:100px; padding-top:50px">Misc</h1>
    <h4 style="padding-left:200px; padding-top:25px; padding-bottom:50px;">This is the Misc page! Everything else is here!</h4>
 </div>
<div style=" border-color:ghostwhite; padding-bottom:100px; display:inline-grid; margin:25px; margin-left:50px;">   
    <img style=" height:200px; width:200px;  background-color:none" src="/lib/chaosmod_icon.png" asp-append-version="true" alt="oops" />
    <div style="display:inline-flex">
        <h1 style="margin-top:25px;">AAO</h1>
        <but style="margin-top:75px; margin-left:220px; text-decoration:none; padding-left:30px; padding-right:30px; padding-bottom:0px; font-size:18px">
        <a style="color:black" asp-area="" asp-controller="Misc" asp-action="AAO">View</a>
        </but>
    </div>
 </div>
    
<div style=" border-color:ghostwhite; padding-bottom:100px; display:inline-grid; margin:25px; margin-right:50px;">
    <img style=" height:200px; width:200px;  background-color:none" src="/lib/chaosmod_icon.png" asp-append-version="true" alt="oops" />
    <div style="display:inline-flex">
        <h1 style="margin-top:25px;">Alarm</h1>
        <but style="margin-top:75px; margin-left:220px; text-decoration:none; padding-left:30px; padding-right:30px; padding-bottom:0px; font-size:18px">
            <a style="color:black" asp-area="" asp-controller="Misc" asp-action="Alarm">View</a>
        </but>
    </div>
</div>

